#!/bin/bash
# Dev workspace with 2 windows:
#   Window 1 "work": ~/code/clients
#   Window 2 "config": ~/.config
# Each window: claude (top-left), terminal (bottom-left), nvim (right 65%)

SESSION="dev"
WORKDIR="$HOME/code/clients"
CONFIGDIR="$HOME/.config"

# If already in this session, don't nest
if [ "$TMUX" ] && tmux display-message -p '#S' | grep -q "^${SESSION}$"; then
  echo "Already in $SESSION session"
  exit 0
fi

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux attach -t "$SESSION"
  exit 0
fi

# Helper: create a 3-pane layout in the current window
#   pane 1 = top-left (claude), pane 2 = bottom-left (terminal), pane 3 = right (nvim)
create_layout() {
  local target="$1"
  local dir="$2"

  tmux split-window -h -t "$target" -l 65% -c "$dir"
  tmux split-window -v -t "$target.1" -l 50% -c "$dir"

  tmux select-pane -t "$target.1" -T 'claude'
  tmux select-pane -t "$target.2" -T 'terminal'
  tmux select-pane -t "$target.3" -T 'nvim'

  # Clear each pane after shell initializes to remove prompt artifacts
  sleep 0.1
  tmux send-keys -t "$target.1" 'clear' C-m
  tmux send-keys -t "$target.2" 'clear' C-m
  tmux send-keys -t "$target.3" 'clear' C-m

  tmux select-pane -t "$target.1"
}

# Window 1: work
tmux new-session -d -s "$SESSION" -n 'work' -c "$WORKDIR" -x "$(tput cols)" -y "$(tput lines)"
create_layout "$SESSION:work" "$WORKDIR"

# Window 2: config
tmux new-window -t "$SESSION" -n 'config' -c "$CONFIGDIR"
create_layout "$SESSION:config" "$CONFIGDIR"

# Start on the work window
tmux select-window -t "$SESSION:work"

# Attach
tmux attach -t "$SESSION"
